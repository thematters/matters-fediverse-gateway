{
  auto_https off
}

http://staging-gateway.matters.town:8080 {
  encode zstd gzip

  @private path /admin /admin/* /jobs /jobs/*
  respond @private 404

  reverse_proxy 127.0.0.1:8787

  log {
    output file /var/log/caddy/matters-gateway-core.staging-public.access.log
    format json
  }
}

http://staging-admin.matters.town:8080 {
  encode zstd gzip
  reverse_proxy 127.0.0.1:8787

  log {
    output file /var/log/caddy/matters-gateway-core.staging-admin.access.log
    format json
  }
}
