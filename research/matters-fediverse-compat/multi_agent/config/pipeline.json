{
  "project": {
    "name": "Matters Instance Interoperability Delivery",
    "language": "zh-TW",
    "workspace_root": ".",
    "source_dirs": [
      "raw",
      "docs",
      "processed",
      "outputs",
      "multi_agent/stage_briefs",
      "../../external/ipns-site-generator/src"
    ]
  },
  "shared_prompt": "multi_agent/agents/common_system_prompt.md",
  "orchestrator_prompt": "multi_agent/agents/orchestrator.md",
  "output_template": "multi_agent/templates/agent_output.md",
  "handoff_template": "multi_agent/templates/handoff.md",
  "stages": [
    {
      "id": "stage01_instance_platform",
      "title": "Instance Platform",
      "objective": "定義 Matters 官方 instance 的平台邊界、對外身分、policy 與 launch baseline",
      "brief_path": "multi_agent/stage_briefs/stage01_instance_platform.md",
      "agents": [
        "planner",
        "writer",
        "architect"
      ],
      "deliverables": [
        "stage brief",
        "instance platform spec",
        "ADR-001 federation architecture",
        "ADR-005 instance governance surface"
      ]
    },
    {
      "id": "stage02_identity_and_discovery",
      "title": "Identity And Discovery",
      "objective": "固定 actor ID、WebFinger、aliases、followers/following 與 key ownership 規則",
      "brief_path": "multi_agent/stage_briefs/stage02_identity_and_discovery.md",
      "agents": [
        "writer",
        "architect",
        "reviewer"
      ],
      "deliverables": [
        "identity and discovery spec",
        "ADR-002 canonical identity and discovery",
        "ADR-003 follower state and key ownership",
        "identity review gate"
      ]
    },
    {
      "id": "stage03_gateway_core",
      "title": "Gateway Core",
      "objective": "定義 federation gateway 的 endpoint surface、queue、signatures、state ownership 與 failure model",
      "brief_path": "multi_agent/stage_briefs/stage03_gateway_core.md",
      "agents": [
        "architect",
        "implementer",
        "reviewer",
        "ops_reviewer"
      ],
      "deliverables": [
        "federation gateway spec",
        "gateway review gate",
        "gateway implementation slice",
        "updated interoperability acceptance plan"
      ]
    },
    {
      "id": "stage04_social_interop",
      "title": "Social Interoperability",
      "objective": "定義 Matters 與外部 instance 之間的 social loop、事件映射與 acceptance criteria",
      "brief_path": "multi_agent/stage_briefs/stage04_social_interop.md",
      "agents": [
        "writer",
        "architect",
        "implementer",
        "reviewer"
      ],
      "deliverables": [
        "social interoperability spec",
        "ADR-006 longform object mapping",
        "social loop review gate"
      ]
    },
    {
      "id": "stage05_moderation_and_ops",
      "title": "Moderation And Ops",
      "objective": "定義 moderation、domain policy、abuse handling、delivery retry 與 launch control 面",
      "brief_path": "multi_agent/stage_briefs/stage05_moderation_and_ops.md",
      "agents": [
        "writer",
        "ops_reviewer",
        "reviewer",
        "editor"
      ],
      "deliverables": [
        "moderation and ops spec",
        "ADR-004 public content boundary",
        "operations review gate"
      ]
    },
    {
      "id": "stage06_multi_instance_control_plane",
      "title": "Multi-Instance Control Plane",
      "objective": "定義 instance registry、per-instance config、namespace isolation、policy scope 與 shared service 邊界",
      "brief_path": "multi_agent/stage_briefs/stage06_multi_instance_control_plane.md",
      "agents": [
        "planner",
        "architect",
        "ops_reviewer",
        "reviewer"
      ],
      "deliverables": [
        "multi-instance control plane spec",
        "multi-instance isolation review gate",
        "execution plan update"
      ]
    },
    {
      "id": "stage07_launch_readiness",
      "title": "Launch Readiness",
      "objective": "整合 launch gate、測試矩陣、runbook 與下一輪工程 task，讓後續 agent 可直接進入實作",
      "brief_path": "multi_agent/stage_briefs/stage07_launch_readiness.md",
      "agents": [
        "planner",
        "editor",
        "reviewer",
        "ops_reviewer"
      ],
      "deliverables": [
        "updated next steps",
        "engineering task seeds",
        "launch readiness handoff"
      ]
    }
  ],
  "agents": {
    "planner": "multi_agent/agents/planner.md",
    "writer": "multi_agent/agents/writer.md",
    "architect": "multi_agent/agents/architect.md",
    "implementer": "multi_agent/agents/implementer.md",
    "reviewer": "multi_agent/agents/reviewer.md",
    "editor": "multi_agent/agents/editor.md",
    "ops_reviewer": "multi_agent/agents/ops_reviewer.md"
  }
}
